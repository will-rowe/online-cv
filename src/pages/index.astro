---
import { readFileSync } from 'fs';
import path from 'path';
import yaml from 'js-yaml';
import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import CareerProfile from '../components/CareerProfile.astro';
import Experiences from '../components/Experiences.astro';
import Skills from '../components/Skills.astro';
import Publications from '../components/Publications.astro';
import Teaching from '../components/Teaching.astro';

const raw = readFileSync(path.join(process.cwd(), '_data/info.yaml'), 'utf-8');
const info = yaml.load(raw) as any;

// ── GitHub API ── build-time fetch of public repos
let ghRepos: any[] = [];
let ghSkills: Array<{ name: string; tags: string[] }> = [];
try {
  const ghHeaders: Record<string, string> = { 'Accept': 'application/vnd.github.v3+json' };
  const ghToken = import.meta.env.GITHUB_TOKEN;
  if (ghToken) ghHeaders['Authorization'] = `Bearer ${ghToken}`;
  const ghRes = await fetch(
    `https://api.github.com/users/${info.sidebar.github}/repos?per_page=100&sort=updated`,
    { headers: ghHeaders },
  );
  if (ghRes.ok) {
    const all = await ghRes.json();
    const allNonFork = (all as any[]).filter((r) => !r.fork);

    // Top repos for the software cards
    ghRepos = [...allNonFork]
      .sort((a, b) => b.stargazers_count - a.stargazers_count)
      .slice(0, 12);

    // ── Skill aggregation from ALL non-fork repos ──
    // language field values → group
    const langGroup: Record<string, string> = {
      'Go': 'Languages', 'Python': 'Languages', 'C': 'Languages', 'C++': 'Languages',
      'TypeScript': 'Languages', 'JavaScript': 'Languages', 'Rust': 'Languages',
      'R': 'Languages', 'Shell': 'Infrastructure', 'Groovy': 'Infrastructure',
      'Jupyter Notebook': 'Data & ML',
    };
    // topic strings → group
    const topicGroup: Record<string, string> = {
      // Languages
      'go': 'Languages', 'python': 'Languages', 'typescript': 'Languages',
      'javascript': 'Languages', 'rust': 'Languages', 'cpp': 'Languages',
      // Bioinformatics
      'bioinformatics': 'Bioinformatics', 'genomics': 'Bioinformatics',
      'metagenomics': 'Bioinformatics', 'nanopore': 'Bioinformatics',
      'artic': 'Bioinformatics', 'antibiotic-resistance': 'Bioinformatics',
      'resistome': 'Bioinformatics', 'sequence-analysis': 'Bioinformatics',
      'amplicon': 'Bioinformatics', 'virus': 'Bioinformatics',
      // Infrastructure
      'docker': 'Infrastructure', 'terraform': 'Infrastructure', 'aws': 'Infrastructure',
      'conda': 'Infrastructure', 'nextflow': 'Infrastructure', 'nf-core': 'Infrastructure',
      'snakemake': 'Infrastructure', 'git': 'Infrastructure', 'ipfs': 'Infrastructure',
      // Data & ML
      'machine-learning': 'Data & ML', 'data-sketching': 'Data & ML',
      'minhash': 'Data & ML', 'graph': 'Data & ML', 'bloom-filter': 'Data & ML',
      'probabilistic': 'Data & ML', 'sketching': 'Data & ML',
      // Web
      'react': 'Web', 'webassembly': 'Web', 'wasm': 'Web', 'astro': 'Web',
    };
    // pretty-print overrides for known terms
    const prettyName: Record<string, string> = {
      'nextflow': 'NextFlow', 'nf-core': 'nf-core', 'ipfs': 'IPFS',
      'webassembly': 'WebAssembly', 'wasm': 'WebAssembly',
      'machine-learning': 'Machine Learning', 'data-sketching': 'Data Sketching',
      'antibiotic-resistance': 'Antibiotic Resistance', 'artic': 'ARTIC',
      'sequence-analysis': 'Sequence Analysis', 'bloom-filter': 'Bloom Filter',
    };
    const pretty = (s: string) =>
      prettyName[s] ??
      s.split('-').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');

    const groups: Record<string, Set<string>> = {};
    const addTag = (group: string, tag: string) => {
      if (!groups[group]) groups[group] = new Set();
      groups[group].add(tag);
    };

    for (const r of allNonFork) {
      // primary language
      if (r.language && langGroup[r.language]) {
        addTag(langGroup[r.language], r.language);
      }
      // topics
      for (const t of (r.topics ?? [])) {
        const g = topicGroup[t];
        if (g) addTag(g, pretty(t));
      }
    }

    const groupOrder = ['Languages', 'Bioinformatics', 'Infrastructure', 'Data & ML', 'Web'];
    ghSkills = groupOrder
      .filter((g) => groups[g]?.size > 0)
      .map((g) => ({ name: g, tags: [...groups[g]].sort() }));
  }
} catch { /* fall back to YAML skills */ }

// ── Google Scholar ── read from _data/googleScholar.yaml (generated by scholarScraper.py)
let papers: any[] = [];
let scholarIntro: string = '';
try {
  const { existsSync } = await import('fs');
  const scholarPath = path.join(process.cwd(), '_data/googleScholar.yaml');
  if (existsSync(scholarPath)) {
    const scholarRaw = readFileSync(scholarPath, 'utf-8');
    const scholarData = yaml.load(scholarRaw) as any;
    scholarIntro = scholarData.introduction ?? '';
    // Use firstAuthorPapers for the CV highlight; fall back to all papers
    const source: any[] = scholarData.firstAuthorPapers?.length
      ? scholarData.firstAuthorPapers
      : (scholarData.papers ?? []);
    papers = source.map((p: any) => ({
      title: p.title,
      authors: p.authors,
      journal: p.journal,
      year: p.year,
      cites: p.cites ?? null,
      url: p.link,
    }));
  }
} catch { /* no papers — silent fallback */ }
---

<Base footer={info.footer}>
  <Sidebar slot="sidebar" sidebar={info.sidebar} education={info.education} />

  <CareerProfile profile={info['career-profile']} />
  <Experiences experience={info.experience} />
  <Skills skills={info.skills} ghSkills={ghSkills} />
  <Publications pubs={info.publications} ghRepos={ghRepos} papers={papers} scholarIntro={scholarIntro} />
  <Teaching teaching={info.teaching} />
</Base>
