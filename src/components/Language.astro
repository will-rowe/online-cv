---
import fs from 'fs/promises';
import yaml from 'js-yaml';

const dataPath = new URL('../../_data/info.yaml', import.meta.url);
const raw = await fs.readFile(dataPath, 'utf-8');
const info = yaml.load(raw);
const sidebar = info.sidebar || {};
---

{sidebar.languages && (
  <div class="languages container-block">
    <h2 class="container-block-title">Languages</h2>
    <ul>
      {sidebar.languages.map((l) => (
        <li>{l.idiom} — <span class="muted">{l.level}</span></li>
      ))}
    </ul>
  </div>
)}
