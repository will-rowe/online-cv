---
import fs from 'fs/promises';
import yaml from 'js-yaml';

const dataPath = new URL('../../_data/info.yaml', import.meta.url);
const raw = await fs.readFile(dataPath, 'utf-8');
const info = yaml.load(raw);
const education = info.education || [];
---

{education.length > 0 && (
  <div class="education container-block">
    <h2 class="container-block-title">Education</h2>
    <ul>
      {education.map((e) => (
        <li>
          <strong>{e.degree}</strong> — {e.university} <span class="time">{e.time}</span>
          {e.details && <div>{e.details}</div>}
        </li>
      ))}
    </ul>
  </div>
)}
